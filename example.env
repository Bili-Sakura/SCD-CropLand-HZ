# Copy to `.env` in the repo root and fill in values.
#   cp example.env .env
# `.env` is gitignored. Existing shell exports take precedence over `.env` when using Python `load_project_dotenv`.

# --- SwanLab (training experiment tracking) ---
# https://swanlab.cn
SWANLAB_API_KEY=

# --- Hugging Face Hub ---
# Write token: https://huggingface.co/settings/tokens
HF_TOKEN=

# `scripts/push_to_huggingface.py` — bucket vs git model repo
HF_PUSH_MODE=bucket
HF_BUCKET_ID=BiliSakura/ChangeMambaSCD-JL1-CUP-2024
# Optional subpath inside the bucket (e.g. v1)
HF_BUCKET_PREFIX=
# Used when HF_PUSH_MODE=model
HF_MODEL_REPO_ID=BiliSakura/JL1-ChangeMambaSCD

# Optional: enterprise / mirror Hub API base (huggingface_hub)
# HF_ENDPOINT=https://huggingface.co

# Optional: override folder uploaded by push script
# LOCAL_DIR=
